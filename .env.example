# ╔══════════════════════════════════════════════════════════════════╗
# ║  Gemlink — Environment Variables Template                       ║
# ║  Copy this file to .env.local and fill in your values.          ║
# ║  .env.local is git-ignored. This file is NOT git-ignored.       ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── API Key ────────────────────────────────────────────────────────────────
# Your Google Gemini API key from https://aistudio.google.com/app/apikey
# Required for all AI features.
GEMINI_API_KEY=your_gemini_api_key_here

# APP_URL: The URL where this applet is hosted (Cloud Run / AI Studio).
APP_URL=http://localhost:3015

# ─── AI Models ──────────────────────────────────────────────────────────────
# Override which model is used for each role. If omitted, the defaults in
# config.ts apply. Swap values here to try newer preview models.

# Text/JSON reasoning — plan suggest, scoring, grading, strategy analysis
MODEL_TEXT=gemini-2.5-flash

# Multimodal analysis — video analysis, image labeling, scoring with images
MODEL_MULTIMODAL=gemini-2.5-flash

# Image generation
# Options: gemini-2.5-flash-preview-image, gemini-3-pro-image-preview
MODEL_IMAGE=gemini-2.5-flash-preview-image

# Video generation
# Options: veo-2.0-generate-001, veo-3.1-fast-generate-preview
MODEL_VIDEO=veo-2.0-generate-001

# Text-to-speech / voice generation
# Options: gemini-2.5-flash-preview-tts, gemini-2.5-pro-preview-tts
MODEL_TTS=gemini-2.5-flash-preview-tts

# Prompt expansion and creative writing
MODEL_CREATIVE=gemini-2.5-flash

# Boardroom multi-turn chat sessions
MODEL_BOARDROOM=gemini-2.5-flash

# ─── Generation Defaults ────────────────────────────────────────────────────
# Applied when the user hasn't set a preference.

# Number of image variants to generate per item (1–4)
DEFAULT_IMAGE_COUNT=1

# Default image aspect ratio (1:1 | 16:9 | 9:16 | 4:5)
DEFAULT_ASPECT_RATIO=1:1

# Default image size preset (512 | 1K | 2K)
DEFAULT_IMAGE_SIZE=1K

# Default video resolution (720p | 1080p)
DEFAULT_VIDEO_RESOLUTION=720p

# Default video aspect ratio (16:9 | 9:16 | 1:1)
DEFAULT_VIDEO_ASPECT_RATIO=16:9

# Default TTS voice (Kore | Charon | Fenrir | Aoede | Puck)
DEFAULT_VOICE=Kore

# Default caption style (clean | bold-outline | boxed | typewriter | word-highlight)
DEFAULT_CAPTION_STYLE=clean

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3015

# Maximum video poll attempts before timeout (each attempt ~10s)
MAX_VIDEO_POLL_ATTEMPTS=60

# ─── Feature Flags ──────────────────────────────────────────────────────────
# Set to "false" to disable. Omitting or any other value = enabled.

ENABLE_AUTO_SCORE=true
ENABLE_AUTO_TAG=true
ENABLE_CONFIRM_BEFORE_GENERATE=true
ENABLE_KEN_BURNS_DEFAULT=true

# ─── Frontend (Vite VITE_* vars are exposed to the browser bundle) ──────────
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_MODEL_TEXT=gemini-2.5-flash
VITE_MODEL_IMAGE=gemini-2.5-flash-preview-image
VITE_MODEL_VIDEO=veo-2.0-generate-001
VITE_MODEL_TTS=gemini-2.5-flash-preview-tts
