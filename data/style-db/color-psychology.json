  "composition_psychology": {
    "rule_of_thirds": {
      "effect": "natural, professional, balanced",
      "when": "most general-purpose imagery, product shots, portraits",
      "prompt_hint": "subject positioned off-center using rule of thirds"
    },
    "centered_symmetry": {
      "effect": "authority, power, formal, grand",
      "when": "luxury brands, institutional branding, architecture, hero shots",
      "prompt_hint": "perfectly centered, symmetrical composition, balanced framing"
    },
    "diagonal_lines": {
      "effect": "dynamic, energetic, movement, tension",
      "when": "sports, startups, action brands, technology launch",
      "prompt_hint": "dynamic diagonal composition, strong leading lines, sense of movement"
    },
    "negative_space": {
      "effect": "premium, breathing room, clarity, focus",
      "when": "minimalist brands, text-overlay-needed, hero banners, pitch decks",
      "prompt_hint": "generous negative space, clean background, room for text overlay"
    },
    "layered_depth": {
      "effect": "immersion, richness, storytelling",
      "when": "editorial, campaign imagery, lifestyle brands",
      "prompt_hint": "layered depth with foreground, midground, and background elements"
    },
    "close_crop": {
      "effect": "intimacy, detail, impact, emotional connection",
      "when": "product detail shots, food, beauty, fashion",
      "prompt_hint": "extreme close-up, tight crop, sharp detail, macro perspective"
    }
  },
  "cognitive_load": {
    "low_entropy": {
      "when": "hero images, pitch decks, website backgrounds, thumbnails that need text space",
      "style": "clean, minimal elements, large open areas, monochromatic or limited palette",
      "prompt_hint": "clean minimalist composition, few elements, muted palette, professional"
    },
    "medium_entropy": {
      "when": "blog headers, social posts, product showcases, feature highlights",
      "style": "balanced composition, moderate detail, clear focal point with context",
      "prompt_hint": "balanced composition with clear focal point, moderate detail level"
    },
    "high_entropy": {
      "when": "Instagram feed (scroll-stopper), event posters, youth/Gen Z content",
      "style": "detailed, high contrast, busy-but-purposeful, saturated, pattern-rich",
      "prompt_hint": "high-contrast, visually rich, attention-grabbing, bold colors, detailed"
    }
  }
}
